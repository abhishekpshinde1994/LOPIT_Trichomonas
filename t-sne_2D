# ---- Read the joined data once ----
cat("Reading joined data:", data_file, "\n")
raw_data <- read_xlsx(data_file)
cat("  Raw dimensions:", nrow(raw_data), "x", ncol(raw_data), "\n\n")


###############################################################################
## PART 1: FULL JOINED ANALYSIS (Lojza's approach — all 42 cols as one)
###############################################################################

cat("\n", strrep("=", 70), "\n")
cat("FULL JOINED ANALYSIS (all 42 quanti cols, Lojza's method)\n")
cat(strrep("=", 70), "\n")

joined_dir <- file.path(out_base, "Joined_all42")
dir.create(joined_dir, showWarnings = FALSE, recursive = TRUE)

joined_msnset <- prepare_msnset(raw_data, all_quanti_cols, markers_df, "Joined_all42",
                                rep_blocks = list(repF = 1:14, repB = 15:28, repC = 29:42))

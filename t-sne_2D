cat("JOINED ANALYSIS COMPLETE\n")


###############################################################################
## PART 2: PER-REPLICATE ANALYSIS (each 14-fraction set independently)
###############################################################################

replicate_results <- list()

for (rep_name in names(replicate_info)) {
  
  cat("\n", strrep("=", 70), "\n")
  cat("PROCESSING:", rep_name, "\n")
  cat(strrep("=", 70), "\n")
  

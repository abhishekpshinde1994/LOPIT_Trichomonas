cat("OVERLAP ANALYSIS\n")
cat(strrep("=", 70), "\n\n")

overlap_dir <- file.path(out_base, "Overlap")
dir.create(overlap_dir, showWarnings = FALSE, recursive = TRUE)

all_ids       <- lapply(replicate_results, function(r) rownames(exprs(r$msnset)))

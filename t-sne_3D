# Column layout of the joined data:
#   Col 1 = ID (TVAG_XXXXXX, some multi-protein groups separated by "; ")
#   Col 2 = header (description)
#   Cols  3:16 = repF (14 fractions)
#   Cols 17:30 = repB (14 fractions)
#   Cols 31:44 = repC (14 fractions)
all_quanti_cols <- 3:44
id_col          <- 1
desc_col        <- 2
ids_sep         <- "; "

# Filtering: match Lojza — only drop rows with >= filterRows NAs across ALL
# 42 quanti columns. With filterRows=42 this effectively keeps everything.
filterRows      <- 42

# SVM: Lojza used fixed sigma/cost (no grid search), t_cutoff = 0.4
svm_sigma           <- 0.1
svm_cost            <- 16
svm_t_cutoff        <- 0.4
svm_per_compartment <- TRUE

# t-SNE (3D)
tsne_perplexity <- 30
tsne_max_iter   <- 1000

# Per-replicate column ranges (for individual replicate + overlap analysis)
replicate_info <- list(
  repF = list(abund_cols = 3:16),
  repB = list(abund_cols = 17:30),
  repC = list(abund_cols = 31:44)
)

dir.create(out_base, showWarnings = FALSE, recursive = TRUE)

